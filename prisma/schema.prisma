generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  plan      String
  details   String
  addons    String?
  createdAt DateTime @default(now())
}

model ChatSession {
  id        Int      @id @default(autoincrement())
  email     String?
  history   String
  createdAt DateTime @default(now())
}
