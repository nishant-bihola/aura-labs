# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_KEY: Required to view the /admin dashboard (lead pipeline + proposals).
# The dashboard sends this as the `x-admin-key` header; /api/admin-leads and
# /api/generate-proposal reject any request that doesn't match. Set a long
# random value in your Vercel project settings (and locally) — without it the
# admin page is locked.
ADMIN_KEY="set-a-long-random-secret-here"

# ─── AI provider (chat agent, estimator, proposals) ──────────────────────────
# The app uses one OpenAI-compatible layer and picks a backend automatically:
#   LLM_PROVIDER (explicit) → GROQ_API_KEY → GEMINI_API_KEY → Ollama(localhost)
#
# PRODUCTION (free, recommended): create a free key at https://console.groq.com
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"   # optional override
#
# LOCAL DEV with your own Ollama + Hermes (100% free, private):
#   1) ollama pull hermes3
#   2) put these in .env.local:
# LLM_PROVIDER="ollama"
# OLLAMA_HOST="http://localhost:11434"
# OLLAMA_MODEL="hermes3"
